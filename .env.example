# ZENITH — Beispiel-Umgebung. Kopiere zu ".env" und trage die Werte ein.
# WICHTIG: .env niemals committen. Secrets gehören NIE ins Frontend (HTML/JS).

# ---- Basis ----
PUBLIC_SITE_URL=http://127.0.0.1:5097
PORT=5097

# Optional: persistent buyer-data directory. On Render with a Disk use /var/data.
# Leave empty locally to use server/private/db.json.
ZENITH_DATA_DIR=

# Signiert Login-Sessions + leitet Zugangs-Tokens ab. In Produktion ZWINGEND setzen
# (lange Zufallszeichenkette, z. B. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`).
SESSION_SECRET=

# ---- Stripe ----
STRIPE_SECRET_KEY=
# Webhook-Secret (Stripe Dashboard -> Webhook-Endpoint). Ohne diesen ist /api/stripe/webhook deaktiviert.
STRIPE_WEBHOOK_SECRET=

# Stripe Price-IDs je Produkt (price_...)
STRIPE_PRICE_STARTER_GYM_PLAN=
STRIPE_PRICE_GYM_ERNAEHRUNG=
STRIPE_PRICE_KOMPLETT_PAKET=
STRIPE_PRICE_MINI_ESSENSPLAN=
STRIPE_PRICE_MINI_SUPPLEMENT_GUIDE=
STRIPE_PRICE_MINI_CARDIO_PLAN=
STRIPE_PRICE_MINI_SCHLAF_ERHOLUNG=
STRIPE_PRICE_MINI_TECHNIK_CHECKLISTE=

# ---- Rabattcodes (Stripe-Coupons) ----
# Stripe-Coupon-IDs für die Codes aus data/discount-codes.json (coupon_...).
# Erst mit einer echten Coupon-ID reduziert der Code den TATSÄCHLICH von Stripe
# berechneten Betrag — ohne Verknüpfung ist er nur Vorschau/Attribution (regulärer Preis).
# Anlegen: Stripe Dashboard -> Produkte -> Coupons (z. B. 20 % off), ID hier eintragen,
# danach Testkauf machen, BEVOR der Code beworben wird.
STRIPE_COUPON_LAUNCH20=
STRIPE_COUPON_RESET15=
STRIPE_COUPON_FRIEND10=
# Vorlage für Creator-/Partner-Codes: data/discount-codes.json enthält einen
# Beispiel-Eintrag mit stripeCouponEnvKey "STRIPE_COUPON_CREATOR_LEA".
# Erst aktivieren (auskommentieren + Coupon-ID eintragen), wenn die Kooperation
# wirklich startet — vorher den Code nicht bewerben.
# STRIPE_COUPON_CREATOR_LEA=

# ---- Kauf-E-Mail-Versand (Resend, optional) ----
# Ohne diese Variablen wird KEINE Kauf-Bestätigungs-E-Mail versendet.
# Käufer erhalten ihre Zugangslinks trotzdem direkt über die Success-Seite
# nach dem Bezahlen — der Mail-Versand ist ein Zusatz, kein Muss.
# API-Key von resend.com (beginnt mit re_...). NIEMALS committen.
RESEND_API_KEY=
# Absenderadresse (bei Resend verifizierte Domain, z. B. hallo@deine-domain.de).
# MAIL_FROM hat Vorrang; RESEND_FROM_EMAIL wird als Alternative gelesen.
MAIL_FROM=
RESEND_FROM_EMAIL=
# Antwortadresse für Rückfragen der Käufer (Default im Code: synastyles@gmail.com).
MAIL_REPLY_TO=

# ---- Google Login (OAuth) ----
# Google Cloud Console -> OAuth-Client (Webanwendung).
# Autorisierte Redirect-URI: <PUBLIC_SITE_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Nur lokale Tests ----
# DEV_AUTH=1 schaltet Test-Login/-Freischaltung OHNE echte Zahlung frei.
# In PRODUKTION IMMER 0 (oder weglassen). Default ist sicher (aus).
DEV_AUTH=0
