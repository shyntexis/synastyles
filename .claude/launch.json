{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "zenith-static",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-c", "import os,http.server,socketserver; p=int(os.environ.get('PORT','8000')); socketserver.TCPServer(('127.0.0.1',p), http.server.SimpleHTTPRequestHandler).serve_forever()"],
      "autoPort": true
    }
  ]
}
